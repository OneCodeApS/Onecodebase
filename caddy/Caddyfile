# Caddyfile — routes the public subdomains.
#
# CADDY_TLS controls TLS behavior:
#   - "internal"      → Caddy's local CA (good for *.localhost dev)
#   - an email address → Let's Encrypt with that contact address (prod)
#
# In dev, trust Caddy's local CA so browsers stop warning:
#   docker compose exec caddy caddy trust
#   (or import /data/caddy/pki/authorities/local/root.crt on the host)

# api.* is the single public surface for everything client apps consume:
#   /rest/v1/<table>    → PostgREST table CRUD (strip prefix, PostgREST sees /<table>)
#   /rpc/v1/<fn>        → PostgREST RPC (prefix swap: /rpc/v1/foo → /rpc/foo)
#   /auth/v1/*          → dashboard's end-user auth API (signin, signup, refresh, …)
#   /realtime           → dashboard's SSE stream
#   /functions/v1/<fn>  → dashboard's edge-function router
#   /storage/v1/*       → dashboard's storage proxy (issues signed URLs, 302s to MinIO)
{$API_HOST} {
	tls {$CADDY_TLS}

	handle_path /rest/v1/* {
		reverse_proxy postgrest:3000
	}

	handle_path /rpc/v1/* {
		rewrite * /rpc{uri}
		reverse_proxy postgrest:3000
	}

	handle /auth/v1/* {
		reverse_proxy dashboard:3000
	}

	handle /realtime* {
		reverse_proxy dashboard:3000
	}

	handle /functions/v1/* {
		reverse_proxy dashboard:3000
	}

	handle /storage/v1/* {
		reverse_proxy dashboard:3000
	}

	# Everything else on api.* is undefined.
	handle {
		respond 404
	}
}

# dashboard.* is the operator console only. The public API paths live on api.*
# and we explicitly 404 them here so there's a single canonical surface to
# secure, advertise, and configure CORS for.
{$DASHBOARD_HOST} {
	tls {$CADDY_TLS}

	handle /auth/v1/* {
		respond 404
	}
	handle /realtime* {
		respond 404
	}
	handle /functions/v1/* {
		respond 404
	}
	handle /storage/v1/* {
		respond 404
	}

	handle {
		reverse_proxy dashboard:3000
	}
}

# files.* is the storage data plane. Clients never construct URLs on this
# hostname directly — every URL contains a SigV4 query string generated by
# the dashboard (via /storage/v1/object/sign/...) and expires in 60 seconds.
# Effectively a CDN backplane: public DNS, but useless without a fresh,
# dashboard-issued redirect.
{$FILES_HOST} {
	tls {$CADDY_TLS}
	reverse_proxy minio:9000
}
