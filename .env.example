# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# Generate strong secrets with:
#   openssl rand -hex 32   # for SESSION_SECRET, PGRST_JWT_SECRET
#   openssl rand -base64 24 # for passwords

# ─── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Used by PostgREST to connect (role: authenticator).
AUTHENTICATOR_PASSWORD=

# Used by the dashboard to connect (role: dashboard_admin, broad privileges).
# Never exposed via PostgREST.
DASHBOARD_ADMIN_PASSWORD=

# ─── PostgREST ─────────────────────────────────────────────────────────────────
# Symmetric secret used to verify JWTs in incoming requests.
# Mint client JWTs offline with this secret, e.g.:
#   node -e 'const j=require("jsonwebtoken");console.log(j.sign({role:"service_role"},process.env.PGRST_JWT_SECRET))'
PGRST_JWT_SECRET=

# ─── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ─── Dashboard ─────────────────────────────────────────────────────────────────
# At least 32 chars. Encrypts the session cookie.
SESSION_SECRET=

# Comma-separated allowlist of browser origins permitted to call the public
# APIs under api.* (/auth/v1, /functions/v1, /realtime). Empty disables all
# cross-origin browser access; "*" reflects any origin (use only when refresh
# tokens are bearer-only — never with cookies); otherwise list exact origins:
#   AUTH_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com
# Non-browser callers (curl, server-to-server) ignore CORS and keep working.
AUTH_ALLOWED_ORIGINS=

# ─── Public URLs / Caddy ───────────────────────────────────────────────────────
# Hostnames Caddy listens on. Defaults work for local dev (*.localhost).
API_HOST=api.localhost
DASHBOARD_HOST=dashboard.localhost

# Used in the OpenAPI spec PostgREST returns AND as the endPoint the MinIO
# SDK signs storage URLs against. Should match what clients actually hit.
API_PUBLIC_URL=http://api.localhost
DASHBOARD_PUBLIC_URL=http://dashboard.localhost

# Internal URL the dashboard uses to read PostgREST's version on the
# admin → Versions page. Defaults to the in-compose service address; only set
# this if PostgREST is reachable somewhere else.
# POSTGREST_INTERNAL_URL=http://postgrest:3000

# TLS mode for Caddy:
#   internal             → Caddy's local CA (use for *.localhost dev)
#   you@yourdomain.tld   → ACME / Let's Encrypt (use for prod)
CADDY_TLS=internal

# ─── Audit log destination ─────────────────────────────────────────────────────
# Host path that gets mounted into the dashboard container at /audit.
# The dashboard appends JSON Lines audit files under this directory; the
# subdirectory below the mount is set from the dashboard UI.
# Defaults to ./audit-logs/ in the project (gitignored). Override per-deploy.
AUDIT_HOST_PATH=./audit-logs

# ─── Production-only (server uses docker-compose.prod.yml) ─────────────────────
# Your GitHub username or org — wherever the GHCR image is published.
# Only needed on the server; safe to leave blank for local dev.
GHCR_OWNER=

# Pinned to the deployed commit by CI. On a fresh server, leave as `latest`;
# the first deploy will overwrite this line with the actual SHA.
DASHBOARD_IMAGE_TAG=latest
