# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# Generate strong secrets with:
#   openssl rand -hex 32   # for SESSION_SECRET, PGRST_JWT_SECRET
#   openssl rand -base64 24 # for passwords

# ─── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Used by PostgREST to connect (role: authenticator).
AUTHENTICATOR_PASSWORD=

# Used by the dashboard to connect (role: dashboard_admin, broad privileges).
# Never exposed via PostgREST.
DASHBOARD_ADMIN_PASSWORD=

# ─── PostgREST ─────────────────────────────────────────────────────────────────
# Symmetric secret used to verify JWTs in incoming requests.
# Mint client JWTs offline with this secret, e.g.:
#   node -e 'const j=require("jsonwebtoken");console.log(j.sign({role:"service_role"},process.env.PGRST_JWT_SECRET))'
PGRST_JWT_SECRET=

# ─── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# ─── Dashboard ─────────────────────────────────────────────────────────────────
# At least 32 chars. Encrypts the session cookie.
SESSION_SECRET=

# ─── Public URLs / Caddy ───────────────────────────────────────────────────────
# Hostnames Caddy listens on. Defaults work for local dev (*.localhost).
API_HOST=api.localhost
DASHBOARD_HOST=dashboard.localhost
FILES_HOST=files.localhost

# Used in the OpenAPI spec PostgREST returns; should match what clients hit.
API_PUBLIC_URL=http://api.localhost
DASHBOARD_PUBLIC_URL=http://dashboard.localhost
MINIO_PUBLIC_URL=http://files.localhost

# TLS mode for Caddy:
#   internal             → Caddy's local CA (use for *.localhost dev)
#   you@yourdomain.tld   → ACME / Let's Encrypt (use for prod)
CADDY_TLS=internal

# ─── Production-only (server uses docker-compose.prod.yml) ─────────────────────
# Your GitHub username or org — wherever the GHCR image is published.
# Only needed on the server; safe to leave blank for local dev.
GHCR_OWNER=

# Pinned to the deployed commit by CI. On a fresh server, leave as `latest`;
# the first deploy will overwrite this line with the actual SHA.
DASHBOARD_IMAGE_TAG=latest
