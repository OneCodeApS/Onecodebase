# Minimal PgBouncer image. Alpine + the package, no extras.
# Config + userlist are generated by entrypoint.sh from env vars at startup.
FROM alpine:3.20

RUN apk add --no-cache pgbouncer ca-certificates netcat-openbsd \
 && addgroup -S pgbouncer \
 && adduser -S -D -H -G pgbouncer pgbouncer

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh \
 && mkdir -p /etc/pgbouncer /var/run/pgbouncer /var/log/pgbouncer \
 && chown -R pgbouncer:pgbouncer /etc/pgbouncer /var/run/pgbouncer /var/log/pgbouncer

USER pgbouncer
EXPOSE 6432

ENTRYPOINT ["/entrypoint.sh"]
CMD ["pgbouncer", "/etc/pgbouncer/pgbouncer.ini"]
